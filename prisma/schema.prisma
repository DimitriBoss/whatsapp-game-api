// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum BotState {
  START
  AWAITING_NAME
  MAIN_MENU
  PLAYING_ACTION_VERITE
  PLAYING_DEVINETTE
  PLAYING_PENDU
  PLAYING_MORPION
  PLAYING_QUIZ
  PLAYING_EMOJI
  STOPPED
}

enum QuestionType {
  ACTION
  VERITE
  DEVINETTE
  QUIZ
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MorpionStatus {
  WAITING
  PLAYING
  FINISHED
}

// --- MODELES ---

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  phoneNumber        String    @unique // Ex: "+229XXXXXXXX"
  firstName          String?   // Prénom
  lastName           String?   // Nom
  botState           BotState  @default(START) // État actuel dans le jeu
  playedActionVerite Int       @default(0)
  playedDevinette    Int       @default(0)
  playedCount        Int       @default(0)     // Compteur total unifié
  points             Int       @default(0)     // Score / Points accumulés
  role               UserRole  @default(USER)
  isBlocked          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("users")
}

model Question {
  id         String       @id @default(uuid()) @db.Uuid
  text       String
  answer     String?      // Réponse attendue (séparée par | si plusieurs choix/synonymes)
  type       QuestionType // Uniquement ACTION, VERITE, DEVINETTE ou QUIZ
  category   String?      // Catégorie thématique (ex: "culture", "science")
  difficulty Difficulty   @default(EASY)
  language   String       @default("fr")
  active     Boolean      @default(true)  // Soft delete
  createdAt  DateTime     @default(now())

  @@map("questions")
}

model GameSession {
  id                String   @id @default(uuid()) @db.Uuid
  chatId            String   @unique // ID du groupe WhatsApp ou numéro
  currentQuestionId String?  @db.Uuid // ID de la devinette en cours (vide si Action/Vérité)
  attempts          Int      @default(0) // Nombre de tentatives pour la devinette en cours
  history           String[] @db.Uuid // Historique pour éviter de répéter les mêmes questions
  currentGame       String?  // Nom du jeu en cours (ex: "pendu", "morpion")
  gameData          Json?    // Données spécifiques au jeu en cours (grille morpion, mot pendu, etc.)
  lastActivityAt    DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("game_sessions")
}

model AdminLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String   // Numéro ou ID de l'administrateur
  action    String   // Ex: "BLOCK_USER", "ADD_QUESTION"
  target    String   // Ex: "229XXXXXXXX" ou ID question
  metadata  Json?    // Infos supplémentaires
  createdAt DateTime @default(now())

  @@map("admin_logs")
}

model ErrorLog {
  id        String   @id @default(uuid()) @db.Uuid
  scope     String   // Partie de l'application (ex: "whatsapp.service", "quiz.service")
  message   String
  stack     String?  // Stack trace si dispo
  severity  Severity
  createdAt DateTime @default(now())

  @@map("error_logs")
}

model MorpionGame {
  id             String        @id @default(uuid()) @db.Uuid
  inviteCode     String        @unique // Code à 6 caractères
  player1ChatId  String        // Chat ID du joueur 1 (ex: "229XXXXX@c.us")
  player2ChatId  String?       // Chat ID du joueur 2 (vide au début en mode multijoueur)
  board          String        @default("         ") // 9 caractères, espaces par défaut
  currentTurn    Int           @default(1) // 1 ou 2
  status         MorpionStatus @default(WAITING)
  winnerId       String?       // Chat ID du vainqueur ou "DRAW"
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("morpion_games")
}

